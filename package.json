{
    "name": "cloud-integration-sandbox",
    "version": "1.0.0",
    "private": true,
    "workspaces": [
        "apps/api",
        "apps/web"
    ],
    "scripts": {
        "dev:api": "npm run dev --workspace @cloud-integration-sandbox/api",
        "dev:web": "npm run dev --workspace apps/web",
        "test:api": "npm run test --workspace @cloud-integration-sandbox/api -- --run",
        "typecheck:api": "npm run typecheck --workspace @cloud-integration-sandbox/api",
        "typecheck:web": "npm run typecheck --workspace apps/web",
        "build:api": "sam build --template-file infrastructure/template.yaml",
        "build:web": "npm run build --workspace apps/web",
        "deploy:api": "sam deploy --config-file infrastructure/samconfig.toml"
    }
}